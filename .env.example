# ===========================================================
#  이 파일을 복사해서 .env 로 만들고, 실제 키를 채워넣으세요.
#  .env 파일은 절대 깃/외부에 올리지 않습니다 (.gitignore 처리됨).
#  키를 채팅창에 붙여넣지 말고, 여기 .env 파일에 직접 넣으세요.
# ===========================================================

# --- 한국투자증권 (KIS) 모의투자 ---
KIS_ENV=vts                 # vts = 모의투자, prod = 실전 (지금은 vts 고정)
KIS_APP_KEY=여기에_모의_앱키
KIS_APP_SECRET=여기에_모의_앱시크릿
KIS_ACCOUNT_NO=50123456-01  # 모의 계좌번호 (8자리-2자리)

# --- DART 전자공시 ---
DART_API_KEY=여기에_DART_40자리_인증키

# --- Anthropic (AI 분석) ---
# 이 세션 내에서는 비워둬도 동작. 독립 실행 시에만 채우세요.
ANTHROPIC_API_KEY=
